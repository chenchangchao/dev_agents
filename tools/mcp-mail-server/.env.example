QQ_MAIL_HOST=smtp.qq.com
QQ_MAIL_PORT=465
QQ_MAIL_USER=your_qq_email@example.com
QQ_MAIL_PASS=your_qq_smtp_authorization_code
QQ_MAIL_FROM="Your App <your_qq_email@example.com>"
QQ_MAIL_GOTO=recipient@example.com

NETEASE_MAIL_HOST=smtp.163.com
NETEASE_MAIL_PORT=465
NETEASE_MAIL_USER=your_netease_email@163.com
NETEASE_MAIL_PASS=your_netease_smtp_authorization_code
NETEASE_MAIL_FROM="Your App <your_netease_email@163.com>"
NETEASE_MAIL_GOTO=recipient@example.com

GMAIL_HOST=smtp.gmail.com
GMAIL_PORT=587
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_PASS=your_google_app_password
GMAIL_FROM="Your App <your_gmail_address@gmail.com>"
GMAIL_GOTO=recipient@example.com

QQ_MAIL_TEMPLATE=verification
NETEASE_MAIL_TEMPLATE=verification
GMAIL_MAIL_TEMPLATE=verification

QQ_MAIL_SUBJECT=Your verification code is {{CODE}}
NETEASE_MAIL_SUBJECT=Your verification code is {{CODE}}
GMAIL_MAIL_SUBJECT=Your verification code is {{CODE}}

QQ_MAIL_CONTENT=Your verification code is {{CODE}}. It expires in {{EXPIRE_TIME}}.
NETEASE_MAIL_CONTENT=Your verification code is {{CODE}}. It expires in {{EXPIRE_TIME}}.
GMAIL_MAIL_CONTENT=Your verification code is {{CODE}}. It expires in {{EXPIRE_TIME}}.
