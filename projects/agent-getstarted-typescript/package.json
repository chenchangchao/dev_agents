{
  "name": "agent-getstarted-typescript",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "check": "bunx tsc --noEmit",
    "test": "bun test",
