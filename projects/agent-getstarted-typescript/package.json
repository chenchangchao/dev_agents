    "demo:multi": "bun run apps/05-multi-agent/src/index.ts",
    "demo:protocols": "bun run apps/06-protocol-agents/src/index.ts",
    "demo:bus": "bun run apps/07-redis-agents/src/index.ts",
    "demo:evals": "bun run apps/08-agent-evals/src/index.ts",
    "demo:integrated": "bun run apps/09-integrated-demo/src/index.ts",
    "dev:fastify": "bun run apps/09-integrated-demo/src/index.ts"
  },
  "dependencies": {
    "fastify": "^5.4.0",
